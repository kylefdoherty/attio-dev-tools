# Attio OAuth credentials — get these from https://app.attio.com/settings/developers
ATTIO_CLIENT_ID=your_client_id_here
ATTIO_CLIENT_SECRET=your_client_secret_here
ATTIO_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session encryption key — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_random_64_char_hex_string

# Optional: Attio webhook secret for verifying webhook payloads
ATTIO_WEBHOOK_SECRET=
