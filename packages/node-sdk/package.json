{
  "name": "attio-node",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Attio CRM REST API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:record": "VCR_RECORD_MODE=all vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepublishOnly": "yarn build"
  },
  "packageManager": "yarn@4.13.0",
  "keywords": [
    "attio",
    "crm",
    "sdk",
    "api",
    "revops"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.0.18",
    "msw": "^2.12.10",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18",
    "yaml": "^2.8.4"
  }
}
